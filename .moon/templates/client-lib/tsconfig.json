{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "composite": true,
    "incremental": true,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "tsBuildInfoFile": "../../.moon/cache/types/packages/{{ projectName }}-client/tsconfig.tsbuildinfo",
    "outDir": "../../.moon/cache/types/packages/{{ projectName }}-client",
    "rootDir": "src"
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
